---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — Pagani North">
  <section class="contact-page">
    <div class="contact-image" aria-hidden="true"></div>
    <div class="contact-content">
      <p class="eyebrow">Contact Pagani North</p>
      <h1>Say hello.</h1>
      <p>For music, release, press, collaboration, or general inquiries.</p>
      <a class="button button-primary" href="mailto:hello@paganinorth.com">hello@paganinorth.com</a>
      <p class="contact-note">Additional listening and social links will be added as they become available.</p>
    </div>
  </section>
</BaseLayout>
