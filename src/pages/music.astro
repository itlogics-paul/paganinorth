---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Music — Pagani North" description="Listen to music by Pagani North and discover the stories behind the songs." image="/assets/the-ghost-of-the-boy-promo.jpg">
  <section class="page-hero page-hero-music">
    <div>
      <p class="eyebrow">Pagani North</p>
      <h1>Music</h1>
      <p>Acoustic songs shaped by memory, emotional restraint, and the private lives we carry beneath responsibility.</p>
    </div>
  </section>

  <section class="section release-list">
    <article class="release-row">
      <img src="/assets/the-ghost-of-the-boy-promo.jpg" alt="The Ghost of the Boy album promotion" />
      <div>
        <p class="eyebrow">Album · Title track</p>
        <h2>The Ghost of the Boy</h2>
        <p class="lead">Some lives are not lost. They are buried so another life can continue.</p>
        <p>The album centres on the person life circumstances force us to become, and the life that must be forgotten so responsibility can be carried. The title track turns when she arrives and brings the buried moments back—resurrecting the boy who had become a ghost.</p>
        <a class="button button-primary" href="https://distrokid.com/hyperfollow/paganinorth/the-ghost-of-the-boy" target="_blank" rel="noreferrer">Listen everywhere</a>
      </div>
    </article>

    <article class="release-row reverse">
      <img src="/assets/a-little-light-a-little-grace.jpg" alt="A Little Light, A Little Grace cover" />
      <div>
        <p class="eyebrow">Single</p>
        <h2>A Little Light, A Little Grace</h2>
        <p class="lead">A song about loving someone without asking to become the centre of their world.</p>
        <p>Its emotional movement is from insecurity toward acceptance: understanding that a meaningful place in another person's life does not have to be the largest place.</p>
        <a class="button button-outline" href="https://distrokid.com/hyperfollow/paganinorth/a-little-light-a-little-grace" target="_blank" rel="noreferrer">Listen everywhere</a>
      </div>
    </article>
  </section>
</BaseLayout>
